<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="520.0" prefWidth="620.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cqu.pizza.Controller">

    <children>

        <!-- Title -->
        <Label layoutX="240.0" layoutY="20.0" text="Simulation"
               style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

        <!-- Duration label and text field -->
        <Label layoutX="40.0" layoutY="70.0" text="Duration"/>
        <TextField fx:id="durationField" layoutX="130.0" layoutY="66.0"
                   prefWidth="160.0"/>

        <!-- Report TextArea -->
        <TextArea fx:id="reportArea" layoutX="330.0" layoutY="60.0"
                  prefWidth="260.0" prefHeight="300.0" editable="false"
                  wrapText="true"/>

        <!-- Report label below TextArea -->
        <Label layoutX="430.0" layoutY="368.0" text="Report"/>

        <!-- Run and Reset buttons -->
        <Button fx:id="runButton" layoutX="130.0" layoutY="310.0"
                text="Run" prefWidth="80.0" onAction="#handleRun"/>
        <Button fx:id="resetButton" layoutX="230.0" layoutY="310.0"
                text="Reset" prefWidth="80.0" onAction="#handleReset"/>

        <!-- File Name label and text field -->
        <Label layoutX="40.0" layoutY="420.0" text="File Name"/>
        <TextField fx:id="fileNameField" layoutX="130.0" layoutY="416.0"
                   prefWidth="160.0"/>

        <!-- Save and Exit buttons -->
        <Button fx:id="saveButton" layoutX="330.0" layoutY="416.0"
                text="Save" prefWidth="80.0" onAction="#handleSave"/>
        <Button fx:id="exitButton" layoutX="500.0" layoutY="416.0"
                text="Exit" prefWidth="80.0" onAction="#handleExit"/>

    </children>
</AnchorPane>
